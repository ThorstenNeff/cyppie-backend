{
  "_comment": "VERIFY-ON-MAC-MINI DRAFT (ADR-0026/KAN-137). Cyppie realm: a public PKCE client whose Direct-Grant flow is the SIWE authenticator. Imported via `start --import-realm`. The custom-flow binding + authenticatorConfig wiring must be confirmed on a live Keycloak (alias-vs-id resolution on import varies); adjust after the first import.",
  "realm": "cyppie",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": false,
  "duplicateEmailsAllowed": false,
  "clients": [
    {
      "clientId": "cyppie-app",
      "name": "Cyppie KMP App",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": ["cyppie://auth/callback"],
      "webOrigins": ["+"],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "authenticationFlowBindingOverrides": {
        "direct_grant": "siwe-direct-grant"
      }
    }
  ],
  "authenticationFlows": [
    {
      "alias": "siwe-direct-grant",
      "description": "SIWE (EIP-4361) direct-grant: verify a signed message instead of username/password.",
      "providerId": "basic-flow",
      "topLevel": true,
      "builtIn": false,
      "authenticationExecutions": [
        {
          "authenticator": "siwe-authenticator",
          "authenticatorConfig": "siwe-config",
          "requirement": "REQUIRED",
          "priority": 10,
          "userSetupAllowed": false,
          "autheticatorFlow": false
        }
      ]
    }
  ],
  "authenticatorConfig": [
    {
      "alias": "siwe-config",
      "config": {
        "domain": "auth.cyppie.example",
        "chainIds": "1,8453"
      }
    }
  ]
}
