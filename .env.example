# Cyppie Backend — environment template (PRD-08 F6 / ADR-0021/0022 secrets posture).
#
#   cp .env.example .env  &&  chmod 600 .env   →  fill in real values  →  NEVER commit .env
#
# In production on the Mac Mini these come from the host environment (launchd EnvironmentVariables or a
# chmod-600 file sourced before `docker compose up`), NOT from a committed file. .env is gitignored.

# ── Postgres (shared by Keycloak + User-Service; separate databases, see db/init) ──
POSTGRES_USER=cyppie
POSTGRES_PASSWORD=change-me-strong-random

# ── Keycloak bootstrap admin (rotate after first login; see HARDENING.md) ──
KC_ADMIN=admin
KC_ADMIN_PASSWORD=change-me-strong-random
# Public auth hostname (TLS fronted by Caddy, ADR-0022)
KC_HOSTNAME=https://auth.cyppie.example

# ── User-Service ──
# OIDC issuer the service trusts for JWT validation (Keycloak realm) — set with the auth increment.
CYPPIE_OIDC_ISSUER=https://auth.cyppie.example/realms/cyppie
